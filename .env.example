# ============================================================
# CryptoBot - Environment variables
# ============================================================
# Copia este archivo como .env y ajusta los valores:
#   cp .env.example .env
#
# IMPORTANT: El archivo .env NUNCA debe subirse a Git.
# Las credenciales de Coinbase, Telegram y Email se configuran
# desde el dashboard web (se guardan encriptadas en la DB).
# ============================================================

# --- App ---
# Modo de trading por defecto al arrancar sin API keys configuradas
# Si ya tienes API keys guardadas en el dashboard, se ignora
PAPER_MODE=true

# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Host y puerto del servidor
HOST=0.0.0.0
PORT=8080

# --- Encriptacion ---
# Clave Fernet usada para encriptar credenciales en la DB.
# Si no la defines aqui, se auto-genera en data/secret.key
# y persiste en el volumen Docker.
#
# IMPORTANT: Si la pierdes, no podras descifrar las credenciales
# guardadas. Haz backup del archivo data/secret.key por separado.
#
# Para generar una: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=
