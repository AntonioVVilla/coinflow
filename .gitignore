# ============================================================
# CRITICAL: credentials and sensitive data
# ============================================================
# Environment files with any real values
.env
.env.*
!.env.example

# Encryption key (CRITICAL - if leaked, all stored creds are compromised)
secret.key
*.key
!*.pub.key

# Database (contains encrypted API keys + password hashes)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Data volume (DB + secret.key + logs)
data/
!data/.gitkeep

# Logs (may contain tokens or sensitive request data)
*.log
logs/

# Backups
*.bak
*.backup
*.dump
backups/
cryptobot_backup_*.tar.gz

# Exports that may contain private trade history
trades_*.csv
*.csv
!docs/**/*.csv

# ============================================================
